generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Channel {
  SMS
  WEB_CHAT
  VOICE
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum SessionStatus {
  PROPOSED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentMethod {
  CASH
  STRIPE
  VENMO
  ZELLE
  CHECK
  OTHER
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
  CANCELLED
}

enum Intent {
  BOOK
  RESCHEDULE
  CANCEL
  QUESTION_LOGISTICS
  QUESTION_PROGRESS
  PAYMENT
  SMALLTALK
  COMPLAINT
  AMBIGUOUS
  OUT_OF_SCOPE
  NOT_PROCESSED
}

enum ConfidenceTier {
  AUTO
  APPROVE
  ESCALATE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
  EXPIRED
}

enum ApprovalKind {
  REPLY
  PAYMENT_REQUEST
  RECAP
}

enum ActionTaken {
  AUTO_SENT
  QUEUED_FOR_APPROVAL
  ESCALATED
  CLASSIFY_FAILED
  DRAFT_FAILED
  SEND_FAILED
  DELIVERY_FAILED
  SKIPPED_AGENT_PAUSED
}

model Coach {
  id               String   @id @default(cuid())
  name             String
  phone            String
  timezone         String   @default("America/Los_Angeles")
  defaultRateCents       Int      @default(8000)
  stripeAccountId  String?
  stripeChargesEnabled   Boolean  @default(false)
  stripeOnboardingDone   Boolean  @default(false)
  autonomyEnabled  Boolean  @default(true)
  agentPaused      Boolean  @default(false)
  createdAt        DateTime @default(now())

  parents          Parent[]
  kids             Kid[]
  sessions         Session[]
  availability     Availability[]
  messages         Message[]
  agentDecisions   AgentDecision[]
  approvals        ApprovalQueue[]
  payments         Payment[]
}

model Parent {
  id               String   @id @default(cuid())
  coachId          String
  name             String
  phone            String
  preferredChannel Channel  @default(SMS)
  isVerified      Boolean  @default(false)
  createdAt        DateTime @default(now())

  coach            Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  kids             Kid[]
  messages         Message[]

  @@unique([coachId, phone])
  @@index([coachId])
}

model Kid {
  id        String   @id @default(cuid())
  coachId   String
  parentId  String
  name      String
  age       Int
  notes     String   @default("")
  rateCentsOverride Int?
  createdAt DateTime @default(now())

  coach     Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  parent    Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  sessions  Session[]

  @@index([coachId])
  @@index([parentId])
}

model Session {
  id              String        @id @default(cuid())
  coachId         String
  kidId           String
  scheduledAt     DateTime
  durationMinutes Int           @default(60)
  priceCents       Int           @default(0)
  status          SessionStatus @default(PROPOSED)
  paid            Boolean       @default(false)
  paymentMethod   PaymentMethod?
  paidAt           DateTime?
  coachNotes      String        @default("")
  createdAt       DateTime      @default(now())

  coach           Coach         @relation(fields: [coachId], references: [id], onDelete: Cascade)
  kid             Kid           @relation(fields: [kidId], references: [id], onDelete: Cascade)
  payments         Payment[]
  approvals        ApprovalQueue[]

  @@index([coachId, scheduledAt])
  @@index([kidId])
}

model Availability {
  id        String   @id @default(cuid())
  coachId   String
  startAt   DateTime
  endAt     DateTime
  isBlocked Boolean  @default(false)
  reason    String   @default("")
  createdAt DateTime @default(now())

  coach     Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@index([coachId, startAt])
}

model Message {
  id                String           @id @default(cuid())
  coachId           String
  parentId          String
  direction         MessageDirection
  channel           Channel
  providerMessageId String
  content           String
  receivedAt        DateTime         @default(now())
  processedAt       DateTime?

  coach             Coach            @relation(fields: [coachId], references: [id], onDelete: Cascade)
  parent            Parent           @relation(fields: [parentId], references: [id], onDelete: Cascade)
  agentDecisions    AgentDecision[]
  approvals         ApprovalQueue[]

  @@unique([channel, providerMessageId])
  @@index([coachId, receivedAt])
  @@index([parentId])
}

model AgentDecision {
  id          String         @id @default(cuid())
  coachId     String
  messageId   String
  intent      Intent
  confidence  Float?
  tier        ConfidenceTier?
  actionTaken ActionTaken
  reasoning   String?
  llmModel    String?
  tokensIn    Int?
  tokensOut   Int?
  latencyMs   Int?
  createdAt   DateTime       @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?

  coach       Coach          @relation(fields: [coachId], references: [id], onDelete: Cascade)
  message     Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([coachId, createdAt])
  @@index([messageId])
}

model ApprovalQueue {
  id              String         @id @default(cuid())
  coachId         String
  messageId       String
  draftReply      String
  cancelSessionId String?
  sessionId        String?
  kind             ApprovalKind @default(REPLY)
  status          ApprovalStatus @default(PENDING)
  createdAt       DateTime       @default(now())
  resolvedAt      DateTime?
  resolvedBy      String?

  coach           Coach          @relation(fields: [coachId], references: [id], onDelete: Cascade)
  message         Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  session         Session?       @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([coachId, status])
  @@index([messageId])
  @@index([sessionId])
}

model Payment {
  id                  String         @id @default(cuid())
  coachId             String
  sessionId           String
  amountCents         Int
  method              PaymentMethod
  status              PaymentStatus  @default(PENDING)
  stripeCheckoutId    String?        @unique
  stripePaymentIntent String?        @unique
  stripeEventId       String?        @unique
  recordedBy          String
  createdAt           DateTime       @default(now())
  paidAt              DateTime?
  refundedAt          DateTime?
  notes               String         @default("")

  coach               Coach          @relation(fields: [coachId], references: [id], onDelete: Cascade)
  session             Session        @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([coachId, createdAt])
  @@index([sessionId])
}
