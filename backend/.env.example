# ─── Database ────────────────────────────────────────────────────────────────
# App runtime connection — use Neon's pooled URL in production.
DATABASE_URL="postgresql://coach:coach@localhost:5433/coach_local?schema=public"

# Migrations / Prisma CLI — use Neon's direct (unpooled) URL in production.
# Locally this is identical to DATABASE_URL.
DIRECT_URL="postgresql://coach:coach@localhost:5433/coach_local?schema=public"

# ─── Redis ────────────────────────────────────────────────────────────────────
# BullMQ / Redis. Local Docker maps container 6379 to host 6380.
# On Render: use the internal Redis URL (no egress cost).
REDIS_URL="redis://localhost:6380"

# ─── App identity ─────────────────────────────────────────────────────────────
NODE_ENV=development

# The UUID of the single coach row in the DB. Get it after running the seed script.
# Run: SELECT id FROM "Coach" LIMIT 1;
COACH_ID=replace-me-with-coach-uuid-from-db

# ─── Auth tokens ─────────────────────────────────────────────────────────────
# Shared secret for the internal message-ingestion endpoint. Must be >=16 chars.
# Generate with: openssl rand -hex 32
INTERNAL_INGEST_TOKEN=replace-me-with-32-random-bytes

# Bearer token for all coach dashboard endpoints and voice WebSocket.
# Generate with: openssl rand -hex 32
# Must match VITE_DASHBOARD_TOKEN in the frontend .env.
DASHBOARD_TOKEN=replace-me-with-32-random-bytes

# ─── Demo chat ────────────────────────────────────────────────────────────────
# Set to true to enable the /api/demo/* endpoints and /ws/demo-parent WebSocket.
DEMO_PARENT_CHAT_ENABLED=true

# Secret for signing demo parent session JWTs. Must be >=32 chars.
# Generate with: openssl rand -hex 32
DEMO_TOKEN_SECRET=replace-me-with-32-random-bytes

# ─── Voice ───────────────────────────────────────────────────────────────────
# Set to true to enable the /ws/coach-voice WebSocket.
VOICE_ENABLED=true

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Production example: https://coach-ai-assistant.vercel.app
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Required for agent classification and reply drafting.
ANTHROPIC_API_KEY=""

# ─── Twilio (optional — only if doing real SMS demo) ─────────────────────────
# Set TWILIO_WEBHOOK_VERIFY_DISABLED=true in non-production to skip signature check.
TWILIO_AUTH_TOKEN=
TWILIO_WEBHOOK_VERIFY_DISABLED=true
# WhatsApp "From" address for TwilioWhatsAppSender. Default is the shared Twilio sandbox.
# For a registered WhatsApp Business number, set to whatsapp:+<E164>.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Full public URL of this backend, used to verify Twilio webhook signatures.
# Example: https://coach-ai-assistant-backend.onrender.com
PUBLIC_BASE_URL=http://localhost:3002

# ─── Telnyx (optional — only if using Telnyx SMS) ────────────────────────────
# If set, the /api/telnyx/inbound endpoint requires x-telnyx-token header to match.
TELNYX_INGEST_TOKEN=

# ─── VeriOps observability ────────────────────────────────────────────────────
# Set VERIOPS_ENABLED=true to emit agent traces to VeriOps.
VERIOPS_ENABLED=false
OBS_BASE_URL=https://veriops-api.onrender.com
OBS_API_KEY=
OBS_PROJECT_ID=demo
